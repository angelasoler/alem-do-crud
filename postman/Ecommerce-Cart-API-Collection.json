		{
			"name": "2. User Management",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201 or 200', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"pm.test('Response should contain user info', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson).to.have.property('id');",
									"    ",
									"    // Store user_id for later use",
									"    if (responseJson.id) {",
									"        pm.collectionVariables.set('user_id', responseJson.id.toString());",
									"    }",
									"});",
									"",
									"pm.test('Username should match request', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.login).to.eql(pm.collectionVariables.get('username'));",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"{{full_name}}\",\n  \"documentNumber\": \"{{document}}\",\n  \"login\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
