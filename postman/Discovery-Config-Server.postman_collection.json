		{
			"name": "2. Netflix Eureka Discovery Server",
			"description": "Requests to inspect Eureka registration registry dashboard data dynamically.",
			"item": [
				{
					"name": "Get All Registered Applications",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Eureka registry contains application instances', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.applications.application).to.be.an('array');",
									"    pm.expect(jsonData.applications.application.length).to.be.above(0);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "http://localhost:8761/eureka/apps",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8761",
							"path": [
								"eureka",
								"apps"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get User Service Registry Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('User Service instance is registered and UP', function () {",
									"    var jsonData = pm.response.json();",
									"    var app = jsonData.application;",
									"    pm.expect(app.name).to.eql('USER-SERVICE');",
									"    pm.expect(app.instance[0].status).to.eql('UP');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "http://localhost:8761/eureka/apps/USER-SERVICE",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8761",
							"path": [
								"eureka",
								"apps",
								"USER-SERVICE"
							]
						}
					},
					"response": []
				}
			]
		}
