{
	"info": {
		"_postman_id": "discovery-config-server-collection",
		"name": "Spring Cloud Config & Eureka Discovery Demo",
		"description": "Collection to demonstrate Spring Cloud Config Server (port 8888) and Netflix Eureka Discovery Server (port 8761) APIs in the microservices architecture.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Spring Cloud Config Server",
			"description": "Requests to inspect the central configuration properties loaded dynamically by each microservice.",
			"item": [
				{
					"name": "Get User Service Properties",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains name user-service', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.name).to.eql('user-service');",
									"});",
									"",
									"pm.test('Response contains PostgreSQL datasource properties', function () {",
									"    var jsonData = pm.response.json();",
									"    var properties = jsonData.propertySources[0].source;",
									"    pm.expect(properties['spring.datasource.url']).to.include('jdbc:postgresql://user-db:5432/user_db');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8888/user-service/default",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8888",
							"path": [
								"user-service",
								"default"
							]
						}
					},
					"response": []
				},
